# Copy to .env and fill in real values. Never commit .env.

# Required for real scraping (skip with REVIEWS_MOCK=true)
APIFY_API_TOKEN=apify_api_...

# Required for Slack delivery
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Set to "true" to skip all Apify calls and use built-in mock data (demo/dev)
REVIEWS_MOCK=true
